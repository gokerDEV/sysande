classes: {
  actor: {
    shape: person
    style: {
      fill: "#f8fafc"
      stroke: "#334155"
      stroke-width: 2
    }
  }

  system: {
    style: {
      fill: "#e2e8f0"
      stroke: "#0f172a"
      stroke-width: 3
      border-radius: 10
      bold: true
    }
  }

  external: {
    style: {
      fill: "#ffffff"
      stroke: "#64748b"
      stroke-width: 2
      stroke-dash: 5
    }
  }

  service: {
    style: {
      fill: "#f1f5f9"
      stroke: "#475569"
      stroke-width: 2
      border-radius: 8
    }
  }

  data-store: {
    shape: cylinder
    style: {
      fill: "#fef3c7"
      stroke: "#92400e"
      stroke-width: 2
    }
  }

  queue: {
    style: {
      fill: "#fce7f3"
      stroke: "#9d174d"
      stroke-width: 2
      border-radius: 8
    }
  }

  processing: {
    style: {
      fill: "#dcfce7"
      stroke: "#166534"
      stroke-width: 2
      border-radius: 8
    }
  }

  result: {
    style: {
      fill: "#dbeafe"
      stroke: "#1d4ed8"
      stroke-width: 2
      border-radius: 8
    }
  }

  structural: {
    style: {
      stroke: "#475569"
      stroke-width: 2
    }
  }

  data-flow: {
    style: {
      stroke: "#2563eb"
      stroke-width: 2
      animated: true
    }
  }

  event-flow: {
    style: {
      stroke: "#7c3aed"
      stroke-width: 2
      animated: true
      stroke-dash: 5
    }
  }
}
