direction: right

Client: API Consumer
Target: Upstream API

Gateway: Proxy Engine {
  Router
  Validator
  Enforcer
  Proxy

  Router -> Validator: Rule Match
  Validator -> Enforcer: Context Verified
  Enforcer -> Proxy: Quota Approved
}

Queue: Telemetry Event Bus {
  shape: cylinder
}

Billing: Billing Engine {
  Aggregator
  Ledger

  Aggregator -> Ledger: Update Tenant Quota
}

DB: Configuration & State Store {
  shape: cylinder
}

Client -> Gateway.Router: HTTP Request
Gateway.Proxy -> Target: Proxied Request
Target -> Gateway.Proxy: HTTP Response
Gateway.Proxy -> Client: HTTP Response
Gateway.Proxy -> Queue: Emit Metrics (Async) {
  style: {
    stroke-dasharray: 5
  }
}
Queue -> Billing.Aggregator: Consume Stream
Billing.Ledger -> DB: Persist Deductions
