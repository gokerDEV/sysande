specification {
  element actor
  element system
  element externalSystem
}

model {
  actor saasDeveloper {
    title "SaaS Developer"
    description "Manages platform limits, sets pricing, configures APIs."
  }

  actor apiConsumer {
    title "API Consumer"
    description "Consumes API, monitors usage, purchases quotas."
  }

  system saasGatewaySystem {
    title "Gateway & Billing System"
    description "Handles auth, routing, telemetry, rate limiting, and quota enforcement."
  }

  externalSystem paymentGateway {
    title "Payment Gateway"
    description "3rd party payment processor for quota purchases."
  }

  externalSystem identityProvider {
    title "Identity Providers"
    description "Social auth platforms."
  }

  externalSystem commProvider {
    title "Communication Providers"
    description "Email and SMS services."
  }

  externalSystem targetApi {
    title "Upstream SaaS API"
    description "Target services implementing actual business logic."
  }

  saasDeveloper -> saasGatewaySystem "Configures routing, scopes, and pricing"
  apiConsumer -> saasGatewaySystem "Consumes APIs & tracks quota limits"
  apiConsumer -> paymentGateway "Completes transactions"
  saasGatewaySystem -> paymentGateway "Validates webhooks & syncs limits"
  saasGatewaySystem -> identityProvider "Delegates authentication"
  saasGatewaySystem -> commProvider "Dispatches 2FA & alerts"
  saasGatewaySystem -> targetApi "Proxies requests if quota > 0"
}

views {
  view contextView of saasGatewaySystem {
    title "Extended System Context View"
    include *
  }
}
