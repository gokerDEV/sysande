specification {
  element container
  element component
  element externalSystem
}

model {
  externalSystem targetApi
  container eventBus
  container dataStore

  container proxyEngine {
    component requestRouter {
      title "OpenAPI Router"
      description "Matches incoming HTTP requests against OpenAPI schemas."
    }
    component authValidator {
      title "Auth & Scope Validator"
      description "Verifies JWT signatures and required scopes."
    }
    component quotaEnforcer {
      title "Quota Enforcer"
      description "Validates current usage limits before routing."
    }
    component upstreamClient {
      title "Upstream Proxy Client"
      description "Forwards the authenticated request to the target API."
    }
    component telemetryEmitter {
      title "Telemetry Emitter"
      description "Calculates request duration and payload size."
    }
  }

  requestRouter -> authValidator "Passes matched route rules"
  authValidator -> quotaEnforcer "Passes validated user context"
  quotaEnforcer -> dataStore "Reads current quota cache"
  quotaEnforcer -> upstreamClient "Triggers proxy request"
  upstreamClient -> targetApi "Proxies HTTP call"
  upstreamClient -> telemetryEmitter "Returns response metrics"
  telemetryEmitter -> eventBus "Publishes usage payload"
}

views {
  view componentView of proxyEngine {
    title "Proxy Engine Component View"
    include *
  }
}
